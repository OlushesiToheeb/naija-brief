# --- OpenRouter (LLM) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any OpenRouter chat model. GLM-5.2 is a strong, cheap default with prompt
# caching; deepseek/deepseek-v4-flash also works well.
OPENROUTER_MODEL=z-ai/glm-5.2

# --- Text to speech (local Kokoro) ---
# Best-rated voices: af_heart, af_bella, bf_emma
TTS_VOICE=af_heart
# Audio storage/delivery format: mp3 (default, universal), opus (smaller), or wav.
AUDIO_FORMAT=mp3
AUDIO_BITRATE=64k

# Reasoning effort for the LLM. "none" disables reasoning tokens (cheaper, and
# avoids truncating the JSON on reasoning models). Use "low"/"medium" if summary
# quality drops, or "default" to leave it to the model.
LLM_REASONING_EFFORT=none

# --- Daily brief schedule (cron, Africa/Lagos) ---
BRIEF_CRON=0 6 * * *

# --- Testing flags ---
# MOCK_LLM=1 builds the brief from headlines without calling OpenRouter (no key needed).
# SKIP_TTS=1 skips audio generation (text-only brief, much faster).
MOCK_LLM=0
SKIP_TTS=0

# --- API server ---
API_PORT=3001
# Comma-separated allowed browser origins (defaults to any localhost in dev).
CORS_ORIGINS=

# --- Rate limiting (per-IP) ---
# Global default window/limit. Paid endpoints (/chat, /ask, /generate) are capped
# tighter per-route in code; /health and /status are never throttled.
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# --- PostgreSQL ---
# Either set DATABASE_URL, or the discrete PG* vars below.
# DATABASE_URL=postgres://user:pass@localhost:5432/naija_brief
PGHOST=localhost
PGPORT=5432
PGDATABASE=naija_brief
PGUSER=
PGPASSWORD=
# Schema is managed by migrations (npm run migration:run). TypeORM auto-sync is
# OFF by default; set DB_SYNC=1 only for throwaway local iteration — never in prod.
# DB_SYNC=1
# Managed Postgres (Supabase, Neon, RDS…) requires TLS. Local Postgres doesn't.
# DB_SSL=1

# --- Web app ---
NEXT_PUBLIC_API_URL=http://localhost:3001
